#!/usr/bin/env expect -f
# Drives Claude Code's TUI to fire /insights and waits for report.html to
# regenerate. Full TUI output streams to your terminal so you can see what's
# happening. Called by insights-per-project.sh and restore-one.sh, but you can
# also run it manually against whatever's currently live in ~/.claude/projects/.

set timeout 60
set report "$env(HOME)/.claude/usage-data/report.html"

set before 0
if {[file exists $report]} {
    set before [file mtime $report]
}
puts "report.html mtime before: $before"

log_user 1
spawn claude

puts "\n--- waiting 8s for TUI to settle ---"
sleep 8

puts "\n--- sending /insights ---"
send "/insights\r"

puts "\n--- watching for 180s ---"
set deadline [expr {[clock seconds] + 180}]
while {[clock seconds] < $deadline} {
    if {[file exists $report]} {
        set after [file mtime $report]
        if {$after != $before} {
            puts "\n>>> report.html mtime changed: $before -> $after"
            sleep 2
            send "/exit\r"
            sleep 2
            exit 0
        }
    }
    expect {
        -timeout 1
        timeout {}
    }
}

puts "\n>>> timed out, report.html unchanged"
send "\003"
sleep 1
send "\003"
exit 2
